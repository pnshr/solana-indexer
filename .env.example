# Solana RPC
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WS_URL=wss://api.mainnet-beta.solana.com

# Program to index
PROGRAM_ID=your_program_id_here
IDL_PATH=./idl.json

# PostgreSQL
DATABASE_URL=postgresql://indexer:indexer@localhost:5432/solana_indexer

# Indexer mode: "batch" | "realtime" | "backfill_then_realtime"
INDEXER_MODE=backfill_then_realtime

# Batch mode options
# Optional inclusive slot range for historical backfill
BATCH_START_SLOT=
BATCH_END_SLOT=
# Optional comma-separated list of specific signatures to process
BATCH_SIGNATURES=
BATCH_SIZE=100

# Retry
MAX_RETRIES=5
INITIAL_RETRY_DELAY_MS=500
MAX_RETRY_DELAY_MS=30000

# API
API_PORT=3000
API_HOST=0.0.0.0
API_AUTH_TOKEN=
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX_REQUESTS=120
ENABLE_METRICS=true

# Realtime operations
REALTIME_HEALTHCHECK_INTERVAL_MS=30000
REALTIME_RECONNECT_DELAY_MS=5000
REALTIME_LAG_WARNING_SLOTS=150

# Batch resume
BATCH_RESUME=true

# Validation / smoke mode
INDEXER_DISABLE_RUN=false

# Optional Docker host port override for PostgreSQL
POSTGRES_PORT=5432

# Logging: debug | info | warn | error
LOG_LEVEL=info
