{
  "name": "solana-universal-indexer",
  "version": "1.0.0",
  "description": "Universal Solana indexer that auto-adapts to any Anchor IDL",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest --runInBand --detectOpenHandles",
    "validate:fast": "node scripts/validate-fast.js",
    "validate:local": "node scripts/validate-local.js",
    "validate:docker": "node scripts/validate-docker.js"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@solana/web3.js": "^1.95.0",
    "bs58": "^5.0.0",
    "express": "^4.21.0",
    "pg": "^8.13.0",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.0",
    "dotenv": "^16.4.5",
    "bn.js": "^5.2.1",
    "knex": "^3.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/pg": "^8.11.10",
    "@types/node": "^22.5.0",
    "@types/bn.js": "^5.1.6",
    "typescript": "^5.5.0",
    "ts-node": "^10.9.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "@types/jest": "^29.5.0"
  }
}
